# --- Required: tenant + API the resource server validates against ---
# Issuer and JWKS URI are discovered from the tenant at runtime; do not set them.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# --- M2M client credentials (used by get_token.py to MINT tokens, not by the
#     resource server to validate them). Keep these out of source control. ---
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# --- Optional: validation/runtime tuning (sensible defaults applied) ---
# AUTH0_LEEWAY_SECONDS=60        # clock-skew tolerance for exp/nbf/iat
# API_REQUIRED_SCOPE=read:data   # scope required by /api/protected
# AUTH0_HTTP_TIMEOUT=5           # timeout (s) for discovery/JWKS fetches
# JWKS_CACHE_TTL_SECONDS=3600    # how long to cache JWKS before refresh
# FLASK_DEBUG=false              # never enable in production
